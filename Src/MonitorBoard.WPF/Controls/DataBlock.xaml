<UserControl x:Class="MonitorBoard.WPF.Controls.DataBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonitorBoard.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="80">
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Duration="0:0:4"
                                     Storyboard.TargetName="rt"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="360"
                                     RepeatBehavior="Forever"
                                     Timeline.DesiredFrameRate="60">
                    </DoubleAnimation>
                    <DoubleAnimation Duration="0:0:6"
                                     Storyboard.TargetName="rt1"
                                     Storyboard.TargetProperty="Angle"
                                     From="0" To="-360"
                                     RepeatBehavior="Forever"
                                     Timeline.DesiredFrameRate="60">
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Viewbox>
        <Grid Height="80" Width="80">
        <Ellipse Margin="-10" Stroke="#2200CFF8" StrokeThickness="8"
                 StrokeDashArray="0.2,0.4"/>

        <Border BorderThickness="1" CornerRadius="40">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#995AF6FE" Offset="0"/>
                    <GradientStop Color="#0000" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <Border BorderThickness="1" CornerRadius="40" Margin="5">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                    <GradientStop Color="#285C90" Offset="0"/>
                    <GradientStop Color="#22285C90" Offset="0.5"/>
                    <GradientStop Color="#285C90" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <Border BorderThickness="1" CornerRadius="40" Margin="8">
            <Border.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#11285C90" Offset="0.8"/>
                    <GradientStop Color="#44285C90" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <Path Data="M0 28A28 28 0 0 1 28 0" StrokeThickness="5" Margin="12" 
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform>
                <RotateTransform Angle="90" x:Name="rt"/>
            </Path.RenderTransform>

            <Path.Stroke>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="#4FCCFF" Offset="0"/>
                    <GradientStop Color="#402876" Offset="1"/>
                </LinearGradientBrush>
            </Path.Stroke>
        </Path>

        <Path Data="M0 37A37 37 0 0 1 37 0" Stroke="#00CFF8" StrokeThickness="1"
              Margin="3"
              RenderTransformOrigin="0.5,0.5"
              StrokeDashArray="4,3,8,3,30">
            <Path.RenderTransform>
                <RotateTransform Angle="45" x:Name="rt1"/>
            </Path.RenderTransform>
        </Path>

        <Border BorderThickness="1" CornerRadius="40" Margin="20">
            <Border.Background>
                <RadialGradientBrush>
                    <GradientStop Color="#11285C90" Offset="0.8"/>
                    <GradientStop Color="#44285C90" Offset="1"/>
                </RadialGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                    <GradientStop Color="#285C90" Offset="0"/>
                    <GradientStop Color="#22285C90" Offset="0.5"/>
                    <GradientStop Color="#285C90" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="White" Margin="0,0,0,5" >
            <Run Text="{Binding Value,RelativeSource={RelativeSource AncestorType=UserControl}}" FontSize="15"></Run>
            <Run Text="%"></Run>
        </TextBlock>
        <TextBlock Text="{Binding Header,RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#3DDD" VerticalAlignment="Center" HorizontalAlignment="Center" 
                   FontSize="8" Margin="0,20,0,0"/>
    </Grid>       
    </Viewbox>
</UserControl>
