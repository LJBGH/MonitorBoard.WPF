<UserControl x:Class="MonitorBoard.WPF.Controls.PointPosition"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonitorBoard.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="35" d:DesignWidth="100">
    <Grid>
        <Border Height="24" Width="70" BorderThickness="0,0,0,1"
         Margin="15,0,0,0" VerticalAlignment="Center">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="{Binding CenterColor, RelativeSource={RelativeSource AncestorType={x:Type local:PointPosition}, Mode=FindAncestor}}" Offset="0.5"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <RadialGradientBrush GradientOrigin="0.5,1" Center="0.5,1" RadiusX="0.8">
                    <GradientStop Color="{Binding BottomColor, RelativeSource={RelativeSource AncestorType={x:Type local:PointPosition}, Mode=FindAncestor}}" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="0.5"/>
                </RadialGradientBrush>
            </Border.BorderBrush>
        </Border>
        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType={x:Type local:PointPosition}, Mode=FindAncestor}}"
                   Foreground ="{Binding TitleColor, RelativeSource={RelativeSource AncestorType={x:Type local:PointPosition}, Mode=FindAncestor}}" 
                   Margin="10,0,0,0"
            FontSize="11"
            VerticalAlignment="Center"  HorizontalAlignment="Left"/>
        <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType={x:Type local:PointPosition}, Mode=FindAncestor}}"
                   Foreground="{Binding NumberColor, RelativeSource={RelativeSource AncestorType={x:Type local:PointPosition}, Mode=FindAncestor}}"
            Margin="0,0,15,0"
            VerticalAlignment="Center" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
