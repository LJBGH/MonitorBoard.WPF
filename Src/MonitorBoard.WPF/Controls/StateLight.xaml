<UserControl x:Class="MonitorBoard.WPF.Controls.StateLight"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MonitorBoard.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="60" d:DesignWidth="100">
    <UserControl.Resources>
        <ControlTemplate TargetType="CheckBox" x:Key="SwitchButtonTemp">
            <Border CornerRadius="8" Background="#3DDD"
                    Height="35" Width="15"
                    Name="border1">
                <Border Width="15" Height="15" CornerRadius="50"
                        VerticalAlignment="Bottom" HorizontalAlignment="Center"
                        Background="#CCFFFFFF"
                        Name="border2"></Border>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="VerticalAlignment" TargetName="border2" Value="Top"/>
                    <Setter Property="Background" TargetName="border1" Value="Orange"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </UserControl.Resources>
    <Grid>
        <Border CornerRadius="3" Background="{Binding BackColor,RelativeSource={RelativeSource AncestorType={x:Type local:StateLight}, Mode=FindAncestor}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock Margin="10,10,0,0" 
                           Text="一号灯" FontSize="12" Foreground="Green"
                           VerticalAlignment="Top" HorizontalAlignment="Left"
                           Name="text"/>
                <TextBlock  Margin="0,0,0,10"
                            Text="&#xe639;" FontSize="20"
                            FontFamily="{StaticResource IconFont}" 
                            VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Name="lightText">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#3FFF" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=switchBox}" Value="True">
                                    <Setter Property="Foreground" Value="Orange" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=switchBox}" Value="False">
                                    <Setter Property="Foreground" Value="#3FFF" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="统一控制" Margin="10,0,0,0"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Foreground="#CCFFFFFF"
                           Visibility="Hidden"
                           Name="mainText"></TextBlock>
                <CheckBox Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                          Template="{StaticResource SwitchButtonTemp}"
                          IsChecked="{Binding IsChecked,RelativeSource={RelativeSource AncestorType=UserControl},Mode=TwoWay}"
                          Command="{Binding Command, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding CommandParameter, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Name="switchBox">
                </CheckBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
