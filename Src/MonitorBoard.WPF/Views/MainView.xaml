<Window x:Class="MonitorBoard.WPF.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MonitorBoard.WPF.Views" 
        xmlns:cont="clr-namespace:MonitorBoard.WPF.Controls"
        xmlns:lvc ="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:conv ="clr-namespace:MonitorBoard.WPF.Common.Converter"
        mc:Ignorable="d"
        Title="学习卡监控大屏"
        WindowStartupLocation="CenterScreen"
        Background="#EBEBF5"
        FontFamily="{DynamicResource Jinbuti}"
        Height="650" Width="1150">
    <!--表示完全移除系统默认边框、标题栏和按钮，把整个窗口的控制权交给开发者。-->
    <WindowChrome.WindowChrome>
        <WindowChrome NonClientFrameEdges="None" UseAeroCaptionButtons="False"></WindowChrome>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <FontFamily x:Key="Jinbuti">../Assets/Fonts/#钉钉进步体</FontFamily>
        <FontFamily x:Key="IconFont">../Assets/Fonts/#iconfont</FontFamily>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <!--按钮通用样式-->
        <Style TargetType="Button" x:Key="ControlButtonStyle">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Name="border">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2FFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4FFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--属性按钮样式-->
        <Style x:Key="SerialPropertyButtonStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="#3FFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Background="Transparent">
                            <TextBlock Text="属性" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       FontSize="11" Foreground="#3FFF" Name="txt"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="TextDecorations" TargetName="txt" Value="Underline"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="TextDecorations" TargetName="txt" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--连接按钮样式-->
        <Style x:Key="ConnectButtonStyle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="1"
                                    Background="#772F67BC"  Height="35" CornerRadius="0,18,18,0" 
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Name="border_1">
                                <TextBlock Text="连接设备" Width="50" Margin="15,0,10,0"
                                           FontSize="11" Foreground="White" TextAlignment="Center"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Name="txt"/>
                            </Border>
                            <Canvas HorizontalAlignment="Left" Margin="10,-3">
                                <Border Width="40" Height="40" CornerRadius="18" Name="border_2">
                                    <Border.Background>
                                        <RadialGradientBrush GradientOrigin="0.4,0.4" Center="0.4,0.4">
                                            <GradientStop Color="#2F67BC" Offset="0"/>
                                            <GradientStop Color="#20477C" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Canvas>
                            <Path Data="M161.2 839.9v-654c0-56.1 60.7-91.1 109.3-63.1l566.3 327c48.6 28 48.6 98.1 0 126.2L270.4 903c-48.5 28-109.2-7.1-109.2-63.1z" Fill="#FFFFFF" 
                                  Stretch="Uniform" Margin="25,0,0,0"
                                  Name="path"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="txt" Property="Text" Value="断开连接"/>
                                <Setter TargetName="border_1" Property="Background" Value="Orange"/>
                                <Setter TargetName="border_2" Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush GradientOrigin="0.4,0.4" Center="0.4,0.4">
                                            <GradientStop Color="Gold" Offset="0"/>
                                            <GradientStop Color="#D07C0E" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="path" Property="Data" Value="M209.645253 863.934444l201.049992 0 0-703.866842L209.645253 160.067602 209.645253 863.934444zM611.804588 863.934444l201.113437 0 0-703.866842L611.804588 160.067602 611.804588 863.934444z"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="txt" Property="Text" Value="连接设备"/>
                                <Setter TargetName="border_1" Property="Background" Value="#772F67BC"/>
                                <Setter TargetName="border_2" Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush GradientOrigin="0.4,0.4" Center="0.4,0.4">
                                            <GradientStop Color="#2F67BC" Offset="0"/>
                                            <GradientStop Color="#20477C" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="path" Property="Data" Value="M161.2 839.9v-654c0-56.1 60.7-91.1 109.3-63.1l566.3 327c48.6 28 48.6 98.1 0 126.2L270.4 903c-48.5 28-109.2-7.1-109.2-63.1z"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--GroupBox样式-->
        <Style TargetType="GroupBox" x:Key="GroupBoxStyle">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#1000" Offset="0"/>
                                    <GradientStop Color="#0000" Offset="0.7"/>
                                </LinearGradientBrush>
                            </Grid.Background>
                            <TextBlock Text="{TemplateBinding Tag}"
                                       FontFamily="{StaticResource IconFont}" Foreground="#DD00CFF8" VerticalAlignment="Center" FontSize="14" Margin="5,0"/>
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" TextBlock.Foreground="#DD00CFF8"
                                            Margin="35,0,0,0"/>
                            <ContentPresenter Grid.Row="1"/>
                            <Border Height="1" VerticalAlignment="Bottom" Margin="0,0,0,3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#9900CFF8" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Path Data="M0 0 3 3 30 3 33 0" Fill="#00CFF8" VerticalAlignment="Bottom"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--发送文本样式-->
        <Style TargetType="Button" x:Key="SendButtonStyle">
            <Setter Property="Foreground" Value="#DDD"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Name="border">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" TargetName="border" Value="#772F67BC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" TargetName="border" Value="#552F67BC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" TargetName="border" Value="#222F67BC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!--模拟器开关样式-->
        <Style TargetType="CheckBox" x:Key="SimulatorChecoBoxStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Width="110" Height="25" BorderThickness="0,0,0,1" CornerRadius="12,0,0,12"
                                Name="border1">
                            <Grid VerticalAlignment="Center" >
                                <Border Margin="15,0" Height="15" Width="15" CornerRadius="3" BorderThickness="1" BorderBrush="Gray"
                                        HorizontalAlignment="Left"
                                        Name="border2">
                                    <TextBlock Text="&#xe620;" Foreground="White" FontFamily="{StaticResource IconFont}" Width="15"  
                                               TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Left"
                                               Visibility="Hidden" Name="txticon"></TextBlock>
                                </Border>
                                <TextBlock  Text="{TemplateBinding Content}" Foreground="White" FontSize="11" 
                                            Margin="0,0,8,0"
                                            VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" TargetName="border2" Value="#0146AE"/>
                                <Setter Property="BorderThickness" TargetName="border2" Value="0"/>
                                <Setter Property="Background" TargetName="border1">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#2000CFF8" Offset="0"/>
                                            <GradientStop Color="#0000CFF8" Offset="0.9"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Visibility" TargetName="txticon" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <ControlTemplate TargetType="CheckBox" x:Key="LintChatButtonTemp">
            <StackPanel Orientation="Horizontal" Margin="5,0">
                <Border Background="Transparent" 
                        CornerRadius="10" BorderThickness="1"
                        BorderBrush="{TemplateBinding Background}"
                        Height="12" Width="12"
                        Name="border">
                </Border>
                <ContentPresenter VerticalAlignment="Center" Margin="5,0" TextBlock.Foreground="#5DDD"/>
            </StackPanel>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" TargetName="border">
                        <Setter.Value>
                            <Binding Path="Background" RelativeSource="{RelativeSource TemplatedParent}"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="717*"/>
            <ColumnDefinition Width="433*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.Background>
            <RadialGradientBrush GradientOrigin="0.8,0.8"
                                 Center="0.8,0.8"
                                 RadiusX="0.7"
                                 RadiusY="1">
                <GradientStop Offset="0" Color="#103156"/>
                <GradientStop Offset="1.5" Color="#141627"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!--头部绘制-->
        <Path Data="M0 0 0 35 200 35C210 35 210 35 218 38C226 46 226 46 236 46
                    L406 46
                    C414 46 414 46 422 38C430 35 430 35 440 35
                    L640 35 640 0"
              Stretch="Fill" Grid.ColumnSpan="2">
            <Path.Fill>
                <RadialGradientBrush GradientOrigin="0.5,1.5"
                                     Center="0.5,1"
                                     RadiusX="0.12" RadiusY="0.5">
                    <GradientStop Offset="0" Color="#1B75E7"/>
                    <GradientStop Offset="0.4" Color="#144594"/>
                    <GradientStop Offset="1" Color="#0D213C"/>
                </RadialGradientBrush>
            </Path.Fill>
            <Path.Stroke>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#47D9FF" Offset="0.5"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Path.Stroke>

        </Path>
        <Grid Margin="180,0,180,0" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Margin="80,0" VerticalAlignment="Center"
                       Foreground="#B2FFFFFF" FontSize="18"
                       Text="MODBUS智能学习卡监控系统"/>
            <!--左侧-->
            <Border BorderBrush="#1B436E" BorderThickness="0,0,2,0"
                    Height="14" VerticalAlignment="Top">
                <Border.RenderTransform>
                    <SkewTransform AngleX="-45"/>
                </Border.RenderTransform>
                <Border BorderBrush="#1B436E" BorderThickness="0,0,2,0" 
                        Margin="0,0,4,0">
                    <Border Margin="0,0,4,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D213C" Offset="0.0"/>
                                <GradientStop Color="#1B436E" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>
            </Border>
            <!--右侧-->
            <Border Grid.Column="2" BorderBrush="#1B436E" BorderThickness="2,0,0,0"
                    Height="14" VerticalAlignment="Top">
                <Border.RenderTransform>
                    <SkewTransform AngleX="45"/>
                </Border.RenderTransform>
                <Border BorderBrush="#1B436E" BorderThickness="2,0,0,0" 
                        Margin="4,0,0,0">
                    <Border Margin="4,0,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0D213C" Offset="1"/>
                                <GradientStop Color="#1B436E" Offset="0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>
            </Border>
        </Grid>
        <StackPanel Margin="10,8,0,0" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left">
            <Image Source="/Assets/Images/Logo.png" Height="20" VerticalAlignment="Center"/>
            <TextBlock Text="朝夕教育-智慧工业" Foreground="#4FFF" Margin="20,0,0,0" 
                       VerticalAlignment="Center"/>
        </StackPanel>
        <!--<TextBlock Text="514515" VerticalAlignment="Center"></TextBlock>-->
        <StackPanel Margin="0,0,10,0" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Grid.Column="1">
            <Button Content="&#xe65a;" Style= "{StaticResource ControlButtonStyle}" Click="btnMin_Click"></Button>
            <Button Content="&#xe660;" Style= "{StaticResource ControlButtonStyle}" Click="btnClose_Click"></Button>
        </StackPanel>
        <TextBlock Text="2026-05-18 00:10:30" 
                   VerticalAlignment="Top" 
                   Width="160"
                   HorizontalAlignment="Right"
                   Margin="0,6,85,0" FontSize="15" Foreground="#4FFF" TextAlignment="Left"
                   Name="currentTimeText" Grid.Column="1"></TextBlock>

        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <UniformGrid Columns="3" Margin="8,0">
                <cont:PointPosition 
                     CenterColor="#331FDCF5"
                     BottomColor="#1FDCF5"
                     TitleColor="#91DBDB"
                     NumberColor="#1FDCF5"
                     Title="正常点位"
                     Value="{Binding PointPositionItems[0].Value}">
                </cont:PointPosition>
                <cont:PointPosition 
                    CenterColor="#33FFFF00"
                    BottomColor="Yellow"
                    TitleColor="#91DBDB"
                    NumberColor="Orange"
                    Title="报警点位"
                    Value="{Binding PointPositionItems[1].Value}">
                </cont:PointPosition>
                <cont:PointPosition 
                    CenterColor="#33D14646"
                    BottomColor="#D14646"
                    TitleColor="#91DBDB"
                    NumberColor="#D14646"
                    Title="控制点位"
                    Value="{Binding PointPositionItems[2].Value}">
                </cont:PointPosition>
            </UniformGrid>
            <Border Grid.Column="2" Margin="10,0" Background="#33596C86" CornerRadius="18">
                <Grid Name="grid_conn">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="串口" Foreground="#3DDD" FontSize="15"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <ComboBox Grid.Column="1" Background="Transparent" Height="28"
                              ItemsSource="{Binding PortList}"
                              SelectedItem="{Binding PortName}"></ComboBox>
                    <CheckBox Grid.Column="2" Style="{StaticResource SerialPropertyButtonStyle}" Name="sp_prop"></CheckBox>
                    <CheckBox Grid.Column="3" Style="{StaticResource ConnectButtonStyle}"
                              IsChecked="{Binding ConnState}"></CheckBox>
                </Grid>
            </Border>

            <!--左侧布局-->
            <UniformGrid Grid.Row="1" Columns="1">
                <GroupBox Header="OLED显示功能模块" Tag="&#xe8ba;" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="25"/>
                            <RowDefinition/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>
                        <Border Margin="20,5" BorderBrush="#2000CFF8" CornerRadius="5" BorderThickness="1">
                            <TextBlock Foreground="#00CFF8" FontFamily="SimSun-ExtB"
                                       Text="{Binding OledText}" FontSize="13"></TextBlock>
                        </Border>
                        <TextBlock Grid.Row="1" Margin="15,0" Text="输入显示文本" Foreground="#9AAA" VerticalAlignment="Top"></TextBlock>
                        <TextBlock Grid.Row="1" Margin="15,0" Foreground="#9AAA" FontSize="10" 
                                   VerticalAlignment="Top" HorizontalAlignment="Right">
                            <Run Text="{Binding ElementName=tb_send_text,Path=Text.Length,Mode=OneWay}"/>
                            <Run Text="/"/>
                            <Run Text="60"/>
                        </TextBlock>
                        <TextBox Grid.Row="2" Margin="20,0" Foreground="#AFFF" Padding="5" 
                                 TextWrapping="Wrap" Background="#2000" BorderThickness="0"
                                 Name="tb_send_text"
                                 Text="{Binding SendText}"></TextBox>
                        <Button Grid.Row="3" Margin="18,5" Content="发送文本" Foreground="Black"
                                Background="#992F67BC"
                                Style="{StaticResource SendButtonStyle}"
                                Command="{Binding SendTextCommand}"></Button>
                    </Grid>
                </GroupBox>
                <GroupBox Header="文本发送日志" Tag="&#xe8ba;" Style="{StaticResource GroupBoxStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding LogItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="8" Height="8" CornerRadius="50" Background="Orange"></Border>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="5,0">
                                            <Hyperlink TextDecorations="None"
                                                       Foreground="#409EFE"
                                                       Command="{Binding DataContext.ReSendTextCommand,RelativeSource={RelativeSource AncestorType=Window}}"
                                                       CommandParameter="{Binding LogContext}">[重发]</Hyperlink>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Text="{Binding LogContext}" Margin="5,0"
                                                   Foreground="#B2FFFFFF"></TextBlock>
                                        <TextBlock Grid.Column="3" Text="{Binding SendTime, StringFormat='HH:mm:ss'}" Margin="5,0"
                                                   Foreground="#3DDD"></TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>
            </UniformGrid>
            <!--仪表布局-->
            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <Border Height="270" Width="150" 
                        Margin="0,80,0,0" BorderBrush="Transparent"
                        VerticalAlignment="Top" HorizontalAlignment="Center"
                         >
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#4000" Offset="0"/>
                            <GradientStop Color="#0000" Offset="0.7"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <cont:Meter Width="150" Height="150" 
                         Margin="0,-80,0,0" VerticalAlignment="Top" HorizontalAlignment="Center"
                         Unit="%" Header="temperature"
                                    Value="{Binding DeviceMeterModel.TemperatureValue}"/>
                        <Grid Margin="0,95,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="50"/>
                            </Grid.RowDefinitions>
                            <Border Width="100" Height="25" BorderThickness="0,0,0,1" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#331FDCF5" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="温度" Foreground="#1FDCF5" TextAlignment="Center" VerticalAlignment="Center"/>
                                <Border.BorderBrush>
                                    <RadialGradientBrush GradientOrigin="0.5,1" Center="0.5,1" RadiusX="0.8">
                                        <GradientStop Color="#1FDCF5" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                            <TextBlock Grid.Row="1"  VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Run Text="[最高]  "  Foreground="#3DDD"/>
                                <Run Text="{Binding DeviceMeterModel.TemperatureMax}" Foreground="White"/>
                                <Run Text="℃" Foreground="#3DDD"/>
                            </TextBlock>
                            <TextBlock Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Run Text="[最低]  "  Foreground="#3DDD"/>
                                <Run Text="{Binding DeviceMeterModel.TemperatureMin}" Foreground="White"/>
                                <Run Text="℃" Foreground="#3DDD"/>
                            </TextBlock>
                            <CheckBox Grid.Row="3" Margin="0,10,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Content="启动模拟数据"
                                      Style="{StaticResource SimulatorChecoBoxStyle}"
                                      IsChecked="{Binding DeviceMeterModel.IsOpenTemperatureSimulated}">
                            </CheckBox>
                            <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="模拟区间" Width="30" Foreground="#3DDD" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                <Border Width="50" Margin="5,0" Background="#33596C86" CornerRadius="2" BorderThickness="0" >
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceMeterModel.TemperatureSimulatedMin}" Margin="0,3" Foreground="#99FFFFFF" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"  />
                                        <Border Margin="5,0" CornerRadius="1" Height="1" Background="#3DDD"></Border>
                                        <TextBlock Text="{Binding DeviceMeterModel.TemperatureSimulatedMax}" Margin="0,3" Foreground="#99FFFFFF" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Height="270" Width="150" 
                        Margin="0,80,0,0" BorderBrush="Transparent"
                        VerticalAlignment="Top" HorizontalAlignment="Center"
                         >
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#4000" Offset="0"/>
                            <GradientStop Color="#0000" Offset="0.7"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <cont:Meter Width="150" Height="150" 
                             Margin="0,-80,0,0" VerticalAlignment="Top" HorizontalAlignment="Center"
                             Unit="%" Header="humidity"
                                   Value="{Binding DeviceMeterModel.HumidityValue}"/>
                        <Grid Margin="0,95,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="50"/>
                            </Grid.RowDefinitions>
                            <Border Width="100" Height="25" BorderThickness="0,0,0,1" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#331FDCF5" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="湿度" Foreground="#1FDCF5" TextAlignment="Center" VerticalAlignment="Center"/>
                                <Border.BorderBrush>
                                    <RadialGradientBrush GradientOrigin="0.5,1" Center="0.5,1" RadiusX="0.8">
                                        <GradientStop Color="#1FDCF5" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                            <TextBlock Grid.Row="1"  VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Run Text="[最高]  "  Foreground="#3DDD"/>
                                    <Run Text="{Binding DeviceMeterModel.HumidityMax}" Foreground="White"/>
                                    <Run Text="℃" Foreground="#3DDD"/>
                            </TextBlock>
                            <TextBlock Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Run Text="[最低]  "  Foreground="#3DDD"/>
                                    <Run Text="{Binding DeviceMeterModel.HumidityMin}" Foreground="White"/>
                                    <Run Text="℃" Foreground="#3DDD"/>
                            </TextBlock>
                            <CheckBox Grid.Row="3" Margin="0,10,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Content="启动模拟数据"
                                      Style="{StaticResource SimulatorChecoBoxStyle}"
                                      IsChecked="{Binding DeviceMeterModel.IsOpenHumiditySimulated}">
                            </CheckBox>
                            <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="模拟区间" Width="30" Foreground="#3DDD" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                <Border Width="50" Margin="5,0" Background="#33596C86" CornerRadius="2" BorderThickness="0" >
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceMeterModel.HumiditySimulatedMin}" Margin="0,3" Foreground="#99FFFFFF" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"  />
                                        <Border Margin="5,0" CornerRadius="1" Height="1" Background="#3DDD"></Border>
                                        <TextBlock Text="{Binding DeviceMeterModel.HumiditySimulatedMax}" Margin="0,3" Foreground="#99FFFFFF" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <Border Grid.Column="2" Height="270" Width="150" 
                        Margin="0,80,0,0" BorderBrush="Transparent"
                        VerticalAlignment="Top" HorizontalAlignment="Center"
                         >
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#4000" Offset="0"/>
                            <GradientStop Color="#0000" Offset="0.7"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <cont:Meter Width="150" Height="150"
                             Margin="0,-80,0,0" VerticalAlignment="Top" HorizontalAlignment="Center"
                             Unit="%" Header="luminance"
                                    Value="{Binding DeviceMeterModel.LuminanceValue}"/>
                        <Grid Margin="0,95,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="35"/>
                                <RowDefinition Height="50"/>
                            </Grid.RowDefinitions>
                            <Border Width="100" Height="25" BorderThickness="0,0,0,1" VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#331FDCF5" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="亮度" Foreground="#1FDCF5" TextAlignment="Center" VerticalAlignment="Center"/>
                                <Border.BorderBrush>
                                    <RadialGradientBrush GradientOrigin="0.5,1" Center="0.5,1" RadiusX="0.8">
                                        <GradientStop Color="#1FDCF5" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="0.5"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                            <TextBlock Grid.Row="1"  VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Run Text="[最高]  "  Foreground="#3DDD"/>
                                    <Run Text="{Binding DeviceMeterModel.LuminanceMax}" Foreground="White"/>
                                    <Run Text="℃" Foreground="#3DDD"/>
                            </TextBlock>
                            <TextBlock Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Run Text="[最低]  "  Foreground="#3DDD"/>
                                    <Run Text="{Binding DeviceMeterModel.LuminanceMin}" Foreground="White"/>
                                    <Run Text="℃" Foreground="#3DDD"/>
                            </TextBlock>
                            <CheckBox Grid.Row="3" Margin="0,10,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                      Content="启动模拟数据"
                                      Style="{StaticResource SimulatorChecoBoxStyle}"
                                      IsChecked="{Binding DeviceMeterModel.IsOpenLuminanceSimulated}">
                            </CheckBox>
                            <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="模拟区间" Width="30" Foreground="#3DDD" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                <Border Width="50" Margin="5,0" Background="#33596C86" CornerRadius="2" BorderThickness="0" >
                                    <StackPanel>
                                        <TextBlock Text="{Binding DeviceMeterModel.LuminanceSimulatedMin}" Margin="0,3" Foreground="#99FFFFFF" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"  />
                                        <Border Margin="5,0" CornerRadius="1" Height="1" Background="#3DDD"></Border>
                                        <TextBlock Text="{Binding DeviceMeterModel.LuminanceSimulatedMax}" Margin="0,3" Foreground="#99FFFFFF" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
                <GroupBox Grid.Row="1" Grid.ColumnSpan="3"
                          Header="实时数据跟踪" Tag="&#xe8ba;" Style="{StaticResource GroupBoxStyle}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right"
                                    Margin="0,-20,10,0" TextBlock.FontSize="10">
                            <CheckBox Content="温度" Background="Orange" Template="{StaticResource LintChatButtonTemp}"
                                      IsChecked="True" Name="temperatureSwitchBox"/>
                            <CheckBox Content="湿度"  Background="Green" Template="{StaticResource LintChatButtonTemp}"
                                      IsChecked="True" Name="humiditySwitchBox"/>
                            <CheckBox Content="亮度" Background="LightBlue" Template="{StaticResource LintChatButtonTemp}"
                                      IsChecked="False"  Name="luminanceSwitchBox"/>
                        </StackPanel>
                        <lvc:CartesianChart Margin="10,5">
                            <lvc:CartesianChart.Series>
                                <lvc:LineSeries Values="{Binding TemperatureChartValues}"
                                                PointGeometrySize="0"
                                                Stroke="#88FF9000"
                                                Title="温度"
                                                Visibility="{Binding IsChecked, Source={x:Reference temperatureSwitchBox}, Converter={StaticResource BoolToVisibilityConverter}}"
                                                StrokeThickness="1">
                                    <lvc:LineSeries.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#88FF9000" Offset="0"/>
                                            <GradientStop Color="#0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </lvc:LineSeries.Fill>
                                </lvc:LineSeries>
                                <lvc:LineSeries Values="{Binding HumidityChartValues}"
                                             PointGeometrySize="0"
                                             Stroke="Green"
                                             Title="湿度"
                                             Visibility="{Binding IsChecked, Source={x:Reference humiditySwitchBox}, Converter={StaticResource BoolToVisibilityConverter}}"
                                             StrokeThickness="1">
                                    <lvc:LineSeries.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Green" Offset="0"/>
                                            <GradientStop Color="#0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </lvc:LineSeries.Fill>
                                </lvc:LineSeries>
                                <lvc:LineSeries Values="{Binding LuminanceChartValues}"
                                             PointGeometrySize="0"
                                             Stroke="LightBlue"
                                             Title="亮度"
                                             Visibility="{Binding IsChecked, Source={x:Reference luminanceSwitchBox}, Converter={StaticResource BoolToVisibilityConverter}}"
                                             StrokeThickness="1">
                                    <lvc:LineSeries.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="LightBlue" Offset="0"/>
                                            <GradientStop Color="#0000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </lvc:LineSeries.Fill>
                                </lvc:LineSeries>
                            </lvc:CartesianChart.Series>
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding}" Foreground="#3FFF">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis MinValue="-10" MaxValue="110" Foreground="#3FFF">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="20" Stroke="#05FFFFFF"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </GroupBox>
            </Grid>
            <Grid Grid.Row="1" Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition/>
                    <RowDefinition Height="200"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Border Margin="35,0,35,15" BorderThickness="0,0,0,50" VerticalAlignment="Bottom">
                        <Border.BorderBrush>
                            <RadialGradientBrush GradientOrigin="0.5,1" Center="0.5,1" RadiusX="1" RadiusY="0.5">
                                <GradientStop Color="#FF004C92" Offset="0"/>
                                <GradientStop Color="#122541" Offset="0.5"/>
                            </RadialGradientBrush>
                        </Border.BorderBrush>
                    </Border>
                    <Grid>
                        <Border Width="40" Height="40" CornerRadius="3"  
                                Margin="50,0,0,0"
                                Background="#0CFFFFFF" VerticalAlignment="Center" HorizontalAlignment="Left"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform Angle="45"/>
                            </Border.RenderTransform>
                            <TextBlock Text="&#xe667;" FontFamily="{StaticResource IconFont}" FontSize="30"
                                       Foreground="{Binding MessageModel.MsgColor}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="-45"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Border>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="110,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding MessageModel.Title}" Foreground="{Binding MessageModel.MsgColor}"/>
                                <TextBlock Text="{Binding MessageModel.MsgTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Margin="10,0" Foreground="#3FFF"/>
                            </StackPanel>
                            <TextBlock Text="{Binding MessageModel.MsgInfo}" Margin="0,5" FontSize="10" Foreground="#8FFF"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <GroupBox Grid.Row="1"
                       Header="状态监控" Tag="&#xe8ba;" Style="{StaticResource GroupBoxStyle}">
                    <UniformGrid Margin="15,2" Columns="2" MaxHeight="220" MaxWidth="250">
                        <cont:StateLight Margin="5" BackColor="#1DDD" IsChecked="{Binding DeviceLights[0].IsChecked,Mode=TwoWay}"
                                         Command="{Binding LightCommand}" CommandParameter="0"/>
                        <cont:StateLight Margin="5" BackColor="#1DDD" IsChecked="{Binding DeviceLights[1].IsChecked,Mode=TwoWay}"
                                         Command="{Binding LightCommand}" CommandParameter="1"/>
                        <cont:StateLight Margin="5" BackColor="#1DDD" IsChecked="{Binding DeviceLights[2].IsChecked,Mode=TwoWay}"
                                         Command="{Binding LightCommand}" CommandParameter="2"/>
                        <cont:StateLight Margin="5" BackColor="#1DDD" IsChecked="{Binding DeviceLights[3].IsChecked,Mode=TwoWay}"
                                         Command="{Binding LightCommand}" CommandParameter="3"/>
                        <cont:StateLight Margin="5" BackColor="#1DDD" IsChecked="{Binding DeviceLights[4].IsChecked,Mode=TwoWay}"
                                         Command="{Binding LightCommand}" CommandParameter="4"/>
                        <cont:StateLight Margin="5" BackColor="#FF265ADA" IsMain="True" IsChecked="{Binding IsMainOpen,Mode=TwoWay}"
                                         Command="{Binding MainLightCommand}"/>
                    </UniformGrid>
                </GroupBox>
                <GroupBox Grid.Row="2"
                     Header="资源占用率" Tag="&#xe8ba;" Style="{StaticResource GroupBoxStyle}">
                    <UniformGrid Rows="1" Columns="2">
                        <cont:DataBlock Margin="20" Value="{Binding SysMemory}" Header="内存" />
                        <cont:DataBlock Margin="20" Value="{Binding SysCpu}" Header="CPU"/>
                    </UniformGrid>
                </GroupBox>
            </Grid>
        </Grid>

        <!--连接属性-->
        <Popup StaysOpen="True" IsOpen="{Binding ElementName=sp_prop,Path=IsChecked}"
               PlacementTarget="{Binding ElementName=grid_conn}"
               Placement="Bottom"
               Width="{Binding ElementName=grid_conn,Path=ActualWidth}"
               AllowsTransparency="True"
               HorizontalOffset="10"
               Margin="435,5,2,0">
            <Border CornerRadius="5" Background="#203551" Margin="10,5" BorderBrush="#3300CFF8" BorderThickness="1">
                <Grid Margin="20,5" TextBlock.FontSize="12" TextBlock.Foreground="#3FFF">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="33"/>
                        <RowDefinition Height="33"/>
                        <RowDefinition Height="33"/>
                        <RowDefinition Height="33"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="波特率" Grid.Row="0" VerticalAlignment="Center"/>
                    <TextBlock Text="校验位" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBlock Text="数据位" Grid.Row="2" VerticalAlignment="Center"/>
                    <TextBlock Text="停止位" Grid.Row="3" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" Height="25" VerticalAlignment="Center"
                              ItemsSource="{Binding BeudRateList}" SelectedItem="{Binding BeudRate}"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Height="25" VerticalAlignment="Center"
                              ItemsSource="{Binding ParityList}" SelectedItem="{Binding Parity}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" Height="25" VerticalAlignment="Center"
                              ItemsSource="{Binding DataBitsList}" SelectedItem="{Binding DataBits}"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" Height="25" VerticalAlignment="Center"
                              ItemsSource="{Binding StopBitsList}" SelectedItem="{Binding StopBits}"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</Window>
